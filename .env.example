# Copy to .env.local and fill in real values. Vercel reads these from
# the dashboard's Environment Variables page.

# ─── Supabase (required) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Cloudflare R2 image storage (optional but recommended for production).
# Set NEXT_PUBLIC_IMAGE_STORAGE_DRIVER=r2 to upload menu/promo/payment images
# through the app API into R2 instead of Supabase Storage.
NEXT_PUBLIC_IMAGE_STORAGE_DRIVER=supabase
R2_ACCOUNT_ID=3eee37a4c6541a72ae598eb1780f499f
R2_ACCESS_KEY_ID=fbe205bc2867372ad71967d7915b6fba
R2_SECRET_ACCESS_KEY=529846bf04f28f44a0b93e524b173a6e0653b033b9d637b71aa5f2df99afe428
R2_BUCKET_NAME=qrmenu
R2_PUBLIC_BASE_URL=https://pub-68f34d49e9bf4af7ba5b116c31887efa.r2.dev

# ─── Sentry error tracking (optional) ─────────────────────────────
# Get DSN from https://sentry.io/ → Project Settings → Client Keys.
# If left blank, Sentry is a no-op and the app runs normally.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Required only for source-map upload at build time (better stack traces).
# Create an auth token at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
