# Copy to .env.local and fill in real values. Vercel reads these from
# the dashboard's Environment Variables page.

# ─── Supabase (required) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# ─── Sentry error tracking (optional) ─────────────────────────────
# Get DSN from https://sentry.io/ → Project Settings → Client Keys.
# If left blank, Sentry is a no-op and the app runs normally.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Required only for source-map upload at build time (better stack traces).
# Create an auth token at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
