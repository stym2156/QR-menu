VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY

# Leave empty on Vercel to use same-origin /api functions.
# For local Fastify backend development, use: http://localhost:4000
VITE_API_URL=

# Use "r2" to upload images through the Vercel/Backend R2 API.
VITE_IMAGE_STORAGE_DRIVER=r2

# Server-only values for Vercel Functions. Do not prefix R2 secrets with VITE_.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY
IMAGE_STORAGE_DRIVER=r2
R2_ACCOUNT_ID=YOUR-R2-ACCOUNT-ID
R2_ACCESS_KEY_ID=YOUR-R2-ACCESS-KEY-ID
R2_SECRET_ACCESS_KEY=YOUR-R2-SECRET-ACCESS-KEY
R2_BUCKET_NAME=YOUR-R2-BUCKET
R2_PUBLIC_BASE_URL=https://YOUR-PUBLIC-R2-DOMAIN
